# Copy this file to .env for local development. Never commit .env.
# Values below contain no credentials. External providers are disabled by default.

# Frontend transcription: browser | mock | websocket
VITE_TRANSCRIPTION_PROVIDER=websocket
VITE_TRANSCRIPTION_WEBSOCKET_URL=ws://localhost:8787/transcription
VITE_SERVER_HTTP_URL=http://127.0.0.1:8787

# Bounded, persistent client audio buffer
VITE_AUDIO_BUFFER_MAX_SECONDS=60
VITE_AUDIO_BUFFER_MAX_BYTES=25000000

# WebSocket reconnect (exponential backoff + jitter)
VITE_WS_RECONNECT_BASE_MS=500
VITE_WS_RECONNECT_MAX_MS=10000
VITE_WS_RECONNECT_MAX_ATTEMPTS=8
VITE_WS_RECONNECT_JITTER_RATIO=0.25
VITE_WS_CONNECTION_TIMEOUT_MS=8000
VITE_WS_HEARTBEAT_INTERVAL_MS=5000
VITE_WS_HEARTBEAT_TIMEOUT_MS=10000
VITE_WS_MAX_BUFFERED_AMOUNT_BYTES=1000000

# Sentence assembly
VITE_SENTENCE_SILENCE_MS=1200
VITE_SENTENCE_MAX_DURATION_MS=20000
VITE_SENTENCE_MAX_CHARS_JA=120
VITE_SENTENCE_MAX_CHARS_EN=300
VITE_SUMMARY_SENTENCE_BATCH_SIZE=3

# Backend STT: mock | browser-compatible | <approved vendor id>
STT_HOST=127.0.0.1
STT_PORT=8787
STT_WEBSOCKET_PATH=/transcription
STT_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
STT_MAX_SESSIONS=20
STT_CONNECTION_TIMEOUT_MS=15000
STT_AUDIO_IDLE_TIMEOUT_MS=30000
STT_SESSION_RESUME_TTL_MS=120000
STT_PROVIDER=mock

# External STT is opt-in twice: select its provider and explicitly enable it.
# Never expose any of these settings as VITE_*.
STT_EXTERNAL_ENABLED=false
STT_API_KEY=
STT_REGION=
STT_MODEL=
STT_ENDPOINT=
STT_LANGUAGE_JA=
STT_LANGUAGE_EN=
STT_HOTWORDS_ENABLED=false
STT_REQUEST_TIMEOUT_MS=15000
STT_MAX_SESSION_SECONDS=
STT_SESSION_BUDGET_USD=
STT_MONTHLY_BUDGET_USD=
STT_MAX_AUDIO_SECONDS_PER_SESSION=

# External integration tests are never part of the normal test suite.
RUN_EXTERNAL_STT_TESTS=false
STT_EVALUATION_FILE=server/data/stt-evaluations.jsonl

# Offline file benchmark only. It never changes Browser/Mock/WebSocket modes and never downloads models.
LOCAL_STT_EXECUTABLE=
LOCAL_STT_BINARY_DIR=server/data/local-stt/bin
LOCAL_STT_MODEL_ID=whisper-base-q5_1
LOCAL_STT_MODEL_DIR=server/data/local-stt/models
LOCAL_STT_ALLOWED_INPUT_ROOTS=server/data/local-stt/input
LOCAL_STT_TEMP_DIR=server/data/local-stt/tmp
LOCAL_STT_RESULT_DIR=server/data/local-stt/results
LOCAL_STT_FFMPEG_PATH=
LOCAL_STT_TIMEOUT_MS=600000
LOCAL_STT_MAX_CONCURRENCY=1
LOCAL_STT_THREADS=4
RUN_LOCAL_STT_TESTS=false

# Realtime Local Whisper. Enable explicitly only after placing the local model and executable.
# Audio stays on this PC; no API key or external STT connection is used.
LOCAL_STT_ENABLED=false
LOCAL_STT_MODEL=small-q5_1
LOCAL_STT_MAX_UTTERANCE_MS=20000
LOCAL_STT_SILENCE_MS=1300
LOCAL_STT_MIN_UTTERANCE_MS=300
LOCAL_STT_PRE_SPEECH_MS=300
LOCAL_STT_MAX_QUEUE_SIZE=10
LOCAL_STT_PROCESS_TIMEOUT_MS=120000
LOCAL_STT_MAX_SESSIONS=1
LOCAL_STT_VAD_RMS_THRESHOLD=0.012
LOCAL_STT_NOISE_FLOOR_MULTIPLIER=3
LOCAL_STT_DEBUG_METRICS=false
LOCAL_STT_DEBUG_AUDIO=false
LOCAL_STT_DEBUG_AUDIO_DIR=server/data/local-stt/debug/realtime-audio
LOCAL_STT_DEBUG_AUDIO_MAX_FILES=20
LOCAL_STT_DEBUG_AUDIO_MAX_BYTES=500000000

# Summary: disabled by default. mock needs no API key or external communication.
SUMMARY_ENABLED=false
SUMMARY_PROVIDER=mock
SUMMARY_INTERVAL_SECONDS=10
OPENAI_API_KEY=
OPENAI_LIVE_SUMMARY_MODEL=
OPENAI_FINAL_SUMMARY_MODEL=
OPENAI_LIVE_REASONING_EFFORT=low
OPENAI_FINAL_REASONING_EFFORT=medium
OPENAI_MAX_OUTPUT_TOKENS=
SUMMARY_USAGE_FILE=server/data/api-usage.jsonl

# Optional application-side limits. Blank means no limit.
SUMMARY_MONTHLY_BUDGET_USD=5
SUMMARY_MEETING_BUDGET_USD=0.5
SUMMARY_MAX_REQUESTS_PER_MEETING=100
SUMMARY_STOP_ON_BUDGET_EXCEEDED=true

# No built-in prices. Register verified prices explicitly by model ID.
# Example shape only (replace values after checking the official pricing page):
# OPENAI_PRICING_JSON={"your-model-id":{"inputUsdPerMillionTokens":0,"outputUsdPerMillionTokens":0}}
OPENAI_PRICING_JSON=

# Post-STT safe correction. Disabled by default. mock is deterministic and sends nothing externally.
LLM_CORRECTION_ENABLED=false
LLM_CORRECTION_PROVIDER=mock
LLM_CORRECTION_TIMEOUT_MS=8000
LLM_CORRECTION_CONCURRENCY=1
LLM_CORRECTION_MAX_INPUT_CHARS=4000
LLM_CORRECTION_MAX_OUTPUT_RATIO=1.6
LLM_CORRECTION_REMOVE_FILLERS=false
LLM_CORRECTION_POLICY_VERSION=safe-correction-v1
# JSON array of {canonical, aliases?, language?, caseSensitive?}; keep real personal data out of shared config.
LLM_CORRECTION_GLOSSARY_JSON=[]
