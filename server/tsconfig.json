{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "skipLibCheck": true,
    "rootDir": "..",
    "outDir": "dist",
    "types": ["node"]
  },
  "include": ["src/**/*.ts", "../shared/protocol.ts"],
  "exclude": ["test/**/*.ts", "dist"]
}
