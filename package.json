{
  "name": "minutes-transcription-app",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite --configLoader runner",
    "dev:server": "tsx server/src/index.ts",
    "benchmark:local": "tsx server/src/providers/local/benchmarkCli.ts",
    "benchmark:local:suite": "tsx server/src/providers/local/benchmarkSuiteCli.ts",
    "benchmark:local:natural": "tsx server/src/providers/local/naturalSpeechBenchmarkCli.ts",
    "benchmark:local:chunk-comparison": "tsx server/src/providers/local/chunkComparisonCli.ts",
    "benchmark:local:chunk-repro": "tsx server/src/providers/local/chunkComparisonReproCli.ts",
    "smoke:local:realtime": "tsx server/src/providers/local/realtimeSmokeCli.ts",
    "compare:local:realtime": "tsx server/src/providers/local/realtimeAudioCompareCli.ts",
    "build": "pnpm run build:frontend && pnpm run build:server",
    "build:frontend": "tsc -b && vite build --configLoader runner",
    "build:server": "tsc -p server/tsconfig.json",
    "preview": "vite preview",
    "typecheck": "tsc -b --pretty false && tsc -p server/tsconfig.json --noEmit --pretty false",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "devDependencies": {
    "@eslint/js": "^9.32.0",
    "@types/node": "^24.0.15",
    "@types/ws": "^8.18.1",
    "eslint": "^9.32.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "tsx": "^4.23.1",
    "typescript": "~5.8.3",
    "typescript-eslint": "^8.38.0",
    "vite": "^7.0.6",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "ws": "^8.21.0"
  }
}
